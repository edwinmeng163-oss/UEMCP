{
  "name": "workflow_run_workflow_json_valid",
  "description": "Plan a workflow supplied as a workflowJson string.",
  "category": "happy_path",
  "expectToolListed": true,
  "executeTool": true,
  "expectToolCallError": false,
  "expectToolCallStructuredFields": {
    "action": "workflow_run",
    "workflowName": "json_supplied_workflow",
    "status": "planned",
    "dryRun": true,
    "totalSteps": 1,
    "plannedSteps": 1
  },
  "request": {
    "jsonrpc": "2.0",
    "id": 332,
    "method": "tools/call",
    "params": {
      "name": "unreal.workflow_run",
      "arguments": {
        "workflowJson": "{\"workflowName\":\"json_supplied_workflow\",\"dryRun\":true,\"writeMemory\":false,\"steps\":[{\"name\":\"status\",\"tool\":\"unreal.editor_status\",\"arguments\":{\"includeDetails\":false}}]}"
      }
    }
  }
}
