{
  "name": "material_instance_list_default_content",
  "description": "Read-only material fixture. Lists Material Instance assets under /Game and succeeds even when none exist.",
  "category": "happy_path",
  "expectToolListed": true,
  "executeTool": true,
  "expectToolCallError": false,
  "request": {
    "jsonrpc": "2.0",
    "id": 501,
    "method": "tools/call",
    "params": {
      "name": "unreal.material_instance_list",
      "arguments": {
        "contentRoot": "/Game",
        "recursive": true,
        "limit": 25
      }
    }
  }
}
