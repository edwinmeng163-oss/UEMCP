{
  "name": "skill_list_repo_root_valid",
  "description": "Skill listing should find reviewed repo-root skills when running from a nested example project.",
  "category": "happy_path",
  "expectToolListed": true,
  "executeTool": true,
  "expectToolCallError": false,
  "expectToolCallStructuredFields": {
    "action": "skill_list",
    "skillCount": 1
  },
  "request": {
    "jsonrpc": "2.0",
    "id": 25,
    "method": "tools/call",
    "params": {
      "name": "unreal.skill_list",
      "arguments": {
        "nameFilter": "mcp-self-extension",
        "includeText": false
      }
    }
  }
}
